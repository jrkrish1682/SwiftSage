# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Optional: SWIFT MyStandards credentials (for authenticated connector)
SWIFT_MYSTD_USERNAME=
SWIFT_MYSTD_PASSWORD=
SWIFT_MYSTD_API_KEY=

# Agent settings
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true

# Standards Library
STANDARDS_LIBRARY_PATH=./data/library
SCHEMAS_PATH=./data/schemas
SAMPLES_PATH=./data/samples

# Logging
LOG_LEVEL=INFO
